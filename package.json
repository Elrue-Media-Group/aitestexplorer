{
  "name": "qatool",
  "version": "1.0.0",
  "description": "AI-powered UI automation tool for intelligent website testing and analysis",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "server": "tsx watch src/server.ts",
    "server:prod": "node dist/server.js",
    "ui:dev": "cd ui && npm run dev",
    "ui:build": "cd ui && npm run build",
    "cost": "tsx src/cost-calculator.ts",
    "setup": "npm install && npx playwright install chromium",
    "test": "echo \"Error: no test specified\" && exit 1",
    "mcp:test": "tsx src/mcp-test.ts",
    "mcp:explore": "tsx src/mcp-explore-test.ts"
  },
  "keywords": [
    "automation",
    "testing",
    "ai",
    "playwright",
    "vision"
  ],
  "author": "Tony Cerrato",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/qatool.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/qatool/issues"
  },
  "homepage": "https://github.com/yourusername/qatool#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@playwright/mcp": "^0.0.59",
    "chalk": "^5.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "openai": "^4.20.0",
    "playwright": "^1.40.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/yargs": "^17.0.24",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
