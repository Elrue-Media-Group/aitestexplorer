# OpenAI API Key (REQUIRED)
# Get your API key from: https://platform.openai.com/api-keys
# For trial: You can get free credits when you sign up
OPENAI_API_KEY=sk-your-api-key-here

# Optional: OpenAI Model (default: gpt-4o)
# Alternatives: gpt-4-turbo, gpt-4o-2024-11-20
# Note: gpt-4-vision-preview has been deprecated
OPENAI_MODEL=gpt-4o

# Optional: Exploration Limits (defaults shown)
MAX_PAGES=10
MAX_ACTIONS=50

# Optional: Directory Configuration
SCREENSHOT_DIR=./screenshots
OUTPUT_DIR=./output

# Optional: Run browser in headless mode (true/false)
HEADLESS=false

